+            if emit_event:
+                from src.events.events import reveal_event
+                reveal_event(self)
+        elif (
+            not conditions.get("force_freegame", False)
+            and not conditions.get("force_holdnspin", False)
+            and self.gametype == self.config.basegame_type
+        ):
